    <string name="privacy_section_summary_title">Summary</string>
    <string name="privacy_section_summary_body">Darken is a free, open-source screen dimming overlay. It does not collect, sell, or share personal data. The app has no Internet permission and cannot send data off your device.</string>
    <string name="privacy_section_collect_title">Data collection</string>
    <string name="privacy_section_collect_body">Darken does not collect analytics, advertising identifiers, location, contacts, or any personal information. There are no accounts, crash reporters, or monetization SDKs in the app.</string>
    <string name="privacy_section_storage_title">Data stored on your device</string>
    <string name="privacy_section_storage_body">Settings are saved locally only (e.g. default dimming level, filter color, language, auto-start preference). This data stays in the app\'s private storage on your phone and is not transmitted anywhere.</string>
    <string name="privacy_section_network_title">Network</string>
    <string name="privacy_section_network_body">The app does not request Internet access. It cannot upload or download data. Links you open manually (e.g. GitHub or email from Settings) are handled by your browser or mail app, outside Darken.</string>
    <string name="privacy_section_permissions_title">Permissions</string>
    <string name="privacy_section_permissions_body">Display over other apps: required to draw the dimming overlay. Notifications (Android 13+): required only for the minimal foreground-service icon while dimming is active. Battery optimization exemption: optional recommendation so the system is less likely to stop the service. Darken uses only what it needs to dim the screen; you can review or revoke permissions in system settings.</string>
    <string name="privacy_section_third_party_title">Third-party libraries</string>
    <string name="privacy_section_third_party_body">The app uses standard Android open-source libraries (e.g. AndroidX, Jetpack Compose) shipped with the APK. They run locally on your device and are not used by Darken to collect data.</string>
    <string name="privacy_section_contact_title">Contact &amp; source code</string>
    <string name="privacy_section_contact_body">Questions or privacy concerns: diskus.barge163@simplelogin.com. Source code: https://github.com/lokomaster1/darken</string>
